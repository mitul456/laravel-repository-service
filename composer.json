{
    "name": "mitul456/laravel-repository-service",
    "description": "A Laravel package to generate repository and service layers using artisan commands",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "repository pattern",
        "service layer",
        "clean architecture",
        "php"
    ],
    "authors": [
        {
            "name": "Md Parvez Mosharrof Mitul",
            "email": "mitulmdparvez@gmail.com"
        }
    ],
    "require": {
        "php": "^8.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/console": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Mitul456\\LaravelRepositoryService\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mitul456\\LaravelRepositoryService\\RepositoryServiceProvider"
            ]
        }
    }
}
