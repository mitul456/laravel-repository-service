{
    "name": "mitul456/laravel-repository-service",
    "description": "Repository Pattern and Service Layer Generator for Laravel",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Md Parvez Mosharrof Mitul",
            "email": "mitulmdparvez@gmail.com"
        }
    ],
    "require": {
        "php": "^8.0",
        "illuminate/support": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Mitul456\\LaravelRepositoryService\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mitul456\\LaravelRepositoryService\\RepositoryServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}